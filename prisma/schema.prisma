generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  STUDENT
  PRO
}

enum Role {
  USER
  ADMIN
}

enum ToolType {
  MIND_MAP
  PDF_QUIZ
  REWRITE
  SUMMARIZE
  FLASHCARDS
  REFERENCES
  GRAMMAR
  CHAT_PDF
  AREA_TOOL
  EXAM_SIM
  CASE_STUDY
  LAB_REPORT
  CLINICAL_CASE
  LEGAL_BRIEF
  FORMULA_SHEET
}

enum ContactStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  OVERDUE
}

enum ActivityType {
  REGISTER
  LOGIN
  PAGE_VIEW
  TOOL_USE
  CONTACT_SUBMIT
  BILLING_VIEW
  PLAN_INTEREST
  ADMIN_ACTION
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  area          String?
  course        String?
  university    String?
  credits       Int       @default(15)
  plan          Plan      @default(FREE)
  role          Role      @default(USER)
  adminNote     String?   @db.Text
  creditsReset  DateTime  @default(now())
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  usageLogs      UsageLog[]
  savedItems     SavedItem[]
  activityEvents ActivityEvent[]
  orders         Order[]
  contactLeads   ContactLead[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UsageLog {
  id          String   @id @default(cuid())
  userId      String
  tool        ToolType
  creditsUsed Int
  title       String?
  inputMeta   Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  tool      ToolType
  title     String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tool])
}

model ContactLead {
  id        String        @id @default(cuid())
  userId    String?
  name      String
  email     String
  phone     String
  course    String
  service   String
  deadline  DateTime?
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  adminNote String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([email])
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  description String
  plan        Plan?
  amountCents Int
  status      OrderStatus @default(PENDING)
  adminNote   String?     @db.Text
  paidAt      DateTime?
  dueAt       DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
}

model ActivityEvent {
  id        String       @id @default(cuid())
  userId    String?
  type      ActivityType
  path      String?
  label     String?
  meta      Json?
  createdAt DateTime     @default(now())
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId, createdAt])
}
